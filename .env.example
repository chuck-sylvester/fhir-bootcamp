# -----------------------------------------------------------
# Project-wide .env file (template)
# -----------------------------------------------------------

# Application Settings
APP_NAME="FHIR Demo"
APP_VERSION="0.1.0"
APP_ENV=development
APP_DEBUG=true

# Logging
LOG_LEVEL=INFO

# FHIR Server Endpoints (switch FHIR_BASE_URL to set active)
FHIR_LOCAL_URL="http://localhost:8080/fhir"
FHIR_EXTERNAL_URL_1="https://fhir.medblocks.com/fhir/zWoWdhFBpJ7bL3jVa8VnccPvW39RkU9A"
FHIR_EXTERNAL_URL_2="https://fhir-bootcamp.medblocks.com/fhir"
FHIR_BASE_URL=${FHIR_EXTERNAL_URL_1}

# Public base URL of the FastAPI app (for OAuth2 logout redirect)
BASE_FASTAPI_APP_LOCAL=http://localhost:8000
BASE_FASTAPI_APP_OCI=<public-ip>:8000
APP_BASE_URL=${BASE_FASTAPI_APP_LOCAL}

# PostgreSQL App DB
POSTGRES_APP_HOST=localhost
POSTGRES_APP_PORT=5432
POSTGRES_APP_DB=fachallenge
POSTGRES_APP_USER=fauser
POSTGRES_APP_PASSWORD=<replace with password>

# PostgreSQL Local HAPI FHIR DB
POSTGRES_HAPI_HOST=localhost
POSTGRES_HAPI_PORT=5432
POSTGRES_HAPI_DB=hapifhir
POSTGRES_HAPI_USER=hapiuser
POSTGRES_HAPI_PASSWORD=<replace with password>

# Anthropic
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Keycloak admin (local Keycloak admin console)
KEYCLOAK_ADMIN_PASSWORD=<replace with password>

# Keycloak OAuth2 client (configured in later dev phase)
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=kc-fa-challenge
KEYCLOAK_CLIENT_ID=kc-fa-client
KEYCLOAK_CLIENT_SECRET=<create new secret>

# Session security
# generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=<create new key>
